# ==========================================
# DATABASE
# ==========================================
# If Postgres requires a specific user/password on your local machine
DB_USERNAME=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# ==========================================
# SECURITY
# ==========================================
# From the repo root, run `cd api && bin/rails secret` to generate a secure random string for this!
JWT_SECRET_KEY=

# ==========================================
# CORS
# ==========================================
# Comma-separated list of allowed frontend origins, e.g.:
#   ALLOWED_ORIGINS=http://localhost:3000,https://app.example.com
ALLOWED_ORIGINS=http://localhost:3000

# ==========================================
# FRONTEND
# ==========================================
# Base URL of the frontend application – used in password-reset e-mails
FRONTEND_URL=http://localhost:3000

# ==========================================
# RATE LIMITING (Rack::Attack)
# ==========================================
# Max login attempts per IP per window (default: 5 per 60s)
RACK_ATTACK_LOGIN_LIMIT=5
RACK_ATTACK_LOGIN_PERIOD=60
# Max register/password-reset attempts per IP per window (default: 10 per 60s)
RACK_ATTACK_AUTH_LIMIT=10
RACK_ATTACK_AUTH_PERIOD=60

# ==========================================
# SWAGGER
# ==========================================
SWAGGER_SERVER_URL=
