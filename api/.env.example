# ==========================================
# DATABASE
# ==========================================
# If Postgres requires a specific user/password on your local machine
DB_USERNAME=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# ==========================================
# SECURITY
# ==========================================
# From the repo root, run `cd api && bin/rails secret` to generate a secure random string for this!
JWT_SECRET_KEY=

# ==========================================
# CORS
# ==========================================
# Comma-separated list of allowed frontend origins, e.g.:
#   ALLOWED_ORIGINS=http://localhost:3000,https://app.example.com
ALLOWED_ORIGINS=http://localhost:3000

# ==========================================
# FRONTEND
# ==========================================
# Base URL of the frontend application – used in password-reset e-mails
FRONTEND_URL=http://localhost:3000

# ==========================================
# SWAGGER
# ==========================================
SWAGGER_SERVER_URL=
